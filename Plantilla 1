3) Estado global de aplicacion
====================================================================

```c
// app.h
#ifndef APP_H
#define APP_H

#include <stdint.h>
#include <stdbool.h>

typedef enum {
    ST_INIT = 0,
    ST_TARE,
    ST_ARMED,
    ST_CAPTURE,
    ST_PROCESS,
    ST_DISPLAY,
    ST_ERROR
} app_state_t;

typedef struct {
    float fmax_N;
    float fmean_eff_N;
    float impulse_Ns;
    float time_to_peak_ms;
    float duration_eff_ms;
    float rfd_max_N_per_s;
} impact_metrics_t;

void App_Init(void);
void App_RunOnce(void);

#endif
```

Por que usar enum + struct:
- enum evita errores de estados escritos como numeros sueltos.
- struct agrupa metricas coherentemente y simplifica pasarlas a UI/log.

====================================================================
4) main.c minimo y limpio
====================================================================

```c
// main.c
#include "main.h"
#include "app.h"

int main(void)
{
    // 1) Inicializacion base HAL.
    // Necesaria para SysTick, clocks internos y utilidades HAL.
    HAL_Init();

    // 2) Configuracion de reloj principal (generado por CubeMX).
    // Toda temporizacion posterior depende de esto.
    SystemClock_Config();

    // 3) Inicializacion de perifericos generados por CubeMX.
    // Orden recomendado: GPIO, DMA, ADC, TIM, SPI/UART.
    MX_GPIO_Init();
    MX_DMA_Init();
    MX_ADC1_Init();
    MX_TIM6_Init();
    MX_SPI1_Init();

    // 4) Inicializacion de tu aplicacion de alto nivel.
    App_Init();

    // 5) Bucle principal: no bloqueante, dirigido por estados/eventos.
    while (1)
    {
        App_RunOnce();
    }
}
```

Por que no meter toda la logica en main:
- main debe ser simple; eso facilita migraciones y debug.
- Si todo vive en main, el mantenimiento se vuelve costoso muy rapido.

====================================================================
5) Maquina de estados de aplicacion
====================================================================

```c
// app.c
#include "app.h"
#include "acq.h"
#include "signal_proc.h"
#include "ui.h"
#include "calibration.h"
#include "sample_config.h"

static volatile app_state_t g_state = ST_INIT;
static volatile uint8_t g_reset_requested = 0;
static impact_metrics_t g_metrics;

void App_RequestReset(void)
{
    // Esta funcion se llamara desde EXTI callback (ISR segura).
    // Solo marca bandera para evitar trabajo pesado dentro de interrupcion.
    g_reset_requested = 1;
}

void App_Init(void)
{
    // Inicializa subsistemas de aplicacion.
    UI_Init();
    ACQ_Init();
    CAL_Init();

    // Estado inicial explicito.
    g_state = ST_INIT;
}

void App_RunOnce(void)
{
    // Prioridad global: reset del usuario, salvo si estas en tara critica.
    if (g_reset_requested && g_state != ST_TARE) {
        g_reset_requested = 0;
        g_state = ST_TARE;
    }

    switch (g_state)
    {
    case ST_INIT:
        UI_ShowStatusRed();
        // Transicion inmediata a tara para garantizar baseline limpio.
        g_state = ST_TARE;
        break;

    case ST_TARE:
        UI_ShowStatusRed();
        if (CAL_DoTare()) {
            // Si tara valida, pasamos a espera de impacto.
            g_state = ST_ARMED;
            UI_ShowStatusGreen();
        } else {
            // Si hay ruido excesivo o error ADC, estado de error.
            g_state = ST_ERROR;
        }
        break;

    case ST_ARMED:
        // En armado NO bloquees. Solo vigilas trigger.
        if (ACQ_CheckTrigger(TRIGGER_THRESHOLD_RAW)) {
            g_state = ST_CAPTURE;
        }
        break;

    case ST_CAPTURE:
        // Captura de ventana fija (N muestras) para comparabilidad.
        if (ACQ_StartCaptureAndWait(NSAMPLES)) {
            g_state = ST_PROCESS;
        } else {
            g_state = ST_ERROR;
        }
        break;

    case ST_PROCESS:
        if (PROC_ComputeMetrics(ACQ_GetBuffer(), NSAMPLES, SAMPLE_RATE_HZ, &g_metrics)) {
            g_state = ST_DISPLAY;
        } else {
            g_state = ST_ERROR;
        }
        break;

    case ST_DISPLAY:
        UI_DrawImpactResult(ACQ_GetBuffer(), NSAMPLES, &g_metrics);
        UI_ShowMessage("Pulsa boton para nuevo golpe");
        // Se queda aqui hasta reset.
        break;

    case ST_ERROR:
        UI_ShowError("Error de tara/captura/procesado");
        // Salida por reset.
        break;

    default:
        g_state = ST_ERROR;
        break;
    }
}
```

Por que este diseno funciona bien:
- Estados simples y transiciones claras.
- Facil de depurar con breakpoints por estado.
- Facil de extender (guardar datos, BLE, SD) sin romper lo existente.

