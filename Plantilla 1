====================================================================

```c
// acq.h
#ifndef ACQ_H
#define ACQ_H

#include <stdint.h>
#include <stdbool.h>

void ACQ_Init(void);
bool ACQ_CheckTrigger(uint16_t threshold_raw);
bool ACQ_StartCaptureAndWait(uint32_t nsamples);
const uint16_t* ACQ_GetBuffer(void);

#endif
```

```c
// acq.c
#include "acq.h"
#include "main.h"

// Buffer estatico: evita malloc en embebido.
static uint16_t s_adc_buf[512];  // Ajustar al maximo esperado.
static volatile uint8_t s_capture_done = 0;

void ACQ_Init(void)
{
    // Aqui puedes arrancar ADC en modo continuo ligero para pretrigger,
    // o dejarlo parado hasta trigger segun consumo/estrategia.
}

bool ACQ_CheckTrigger(uint16_t threshold_raw)
{
    // Version simple: leer una muestra "rapida" y comparar umbral.
    // En produccion: filtrar y usar histeresis para evitar falsos disparos.
    uint16_t sample = 0;

    HAL_ADC_Start(&hadc1);
    if (HAL_ADC_PollForConversion(&hadc1, 2) == HAL_OK) {
        sample = (uint16_t)HAL_ADC_GetValue(&hadc1);
    }
    HAL_ADC_Stop(&hadc1);

    return (sample >= threshold_raw);
}

bool ACQ_StartCaptureAndWait(uint32_t nsamples)
{
    if (nsamples > (sizeof(s_adc_buf)/sizeof(s_adc_buf[0]))) {
        return false;
    }

    s_capture_done = 0;

    // Recomendado: ADC configurado con trigger externo de TIM6 TRGO.
    if (HAL_ADC_Start_DMA(&hadc1, (uint32_t*)s_adc_buf, nsamples) != HAL_OK) {
        return false;
    }

    // Arranca timer que marca fs exacta.
    if (HAL_TIM_Base_Start(&htim6) != HAL_OK) {
        HAL_ADC_Stop_DMA(&hadc1);
        return false;
    }

    // Espera activa simple para plantilla.
    // En version final conviene no bloquear (usar estado/evento).
    uint32_t t0 = HAL_GetTick();
    while (!s_capture_done) {
        if ((HAL_GetTick() - t0) > 200U) {
            HAL_TIM_Base_Stop(&htim6);
            HAL_ADC_Stop_DMA(&hadc1);
            return false;
        }
    }

    HAL_TIM_Base_Stop(&htim6);
    HAL_ADC_Stop_DMA(&hadc1);
    return true;
}

const uint16_t* ACQ_GetBuffer(void)
{
    return s_adc_buf;
}

void HAL_ADC_ConvCpltCallback(ADC_HandleTypeDef* hadc)
{
    if (hadc->Instance == ADC1) {
        // Solo bandera: ISR corta.
        s_capture_done = 1;
    }
}
```

Por que es importante este bloque:
- Garantiza muestreo uniforme (clave para analisis temporal).
- Separa captura de procesado y evita mezclar responsabilidades.

