```c
// signal_proc.c
#include "signal_proc.h"

static float RawToForceN(uint16_t raw)
{
    // Placeholder de conversion.
    // Sustituir por calibracion real: F = gain * (V - offset).
    return (float)raw * 0.5f;
}

bool PROC_ComputeMetrics(const uint16_t *raw, uint32_t n, uint32_t fs_hz, impact_metrics_t *out)
{
    if (!raw || !out || n < 2U || fs_hz == 0U) {
        return false;
    }

    const float dt = 1.0f / (float)fs_hz;
    float fmax = 0.0f;
    uint32_t i_peak = 0U;
    float impulse = 0.0f;
    float rfd_max = 0.0f;

    for (uint32_t i = 0; i < n; i++) {
        float f = RawToForceN(raw[i]);
        if (f > fmax) {
            fmax = f;
            i_peak = i;
        }
        impulse += f * dt;

        if (i > 0U) {
            float fp = RawToForceN(raw[i - 1U]);
            float rfd = (f - fp) / dt;
            if (rfd > rfd_max) {
                rfd_max = rfd;
            }
        }
    }

    // Duracion efectiva: tiempo por encima de 50% del pico.
    const float thr = 0.5f * fmax;
    uint32_t neff = 0U;
    float sum_eff = 0.0f;
    for (uint32_t i = 0; i < n; i++) {
        float f = RawToForceN(raw[i]);
        if (f >= thr) {
            neff++;
            sum_eff += f;
        }
    }

    out->fmax_N = fmax;
    out->fmean_eff_N = (neff > 0U) ? (sum_eff / (float)neff) : 0.0f;
    out->impulse_Ns = impulse;
    out->time_to_peak_ms = (1000.0f * (float)i_peak) / (float)fs_hz;
    out->duration_eff_ms = (1000.0f * (float)neff) / (float)fs_hz;
    out->rfd_max_N_per_s = rfd_max;

    return true;
}
```

Por que asi y no mas complejo al inicio:
- Te da metricas utiles ya, sin bloquear por modelado avanzado.
- Una vez estable, puedes mejorar filtros y conversion con datos reales.

