13) Sistema de estados sugerido para firmware
==================================================

Estados tipicos
- INIT
- TARE
- ARMED
- CAPTURE
- PROCESS
- DISPLAY
- ERROR

Regla
- Cada estado hace poco y claro.
- Transiciones por evento.
- Evita logica "todo en while(1) sin estructura".

Esqueleto

```c
typedef enum {
	ST_INIT,
	ST_TARE,
	ST_ARMED,
	ST_CAPTURE,
	ST_PROCESS,
	ST_DISPLAY,
	ST_ERROR
} app_state_t;

volatile app_state_t g_state = ST_INIT;

void App_Run(void)
{
	switch (g_state) {
	case ST_INIT:
		App_InitAll();
		g_state = ST_TARE;
		break;
	case ST_TARE:
		if (Do_Tare()) g_state = ST_ARMED;
		else g_state = ST_ERROR;
		break;
	case ST_ARMED:
		if (g_reset_requested) g_state = ST_TARE;
		else if (Detect_ImpactTrigger()) g_state = ST_CAPTURE;
		break;
	case ST_CAPTURE:
		Start_Capture();
		g_state = ST_PROCESS;
		break;
	case ST_PROCESS:
		if (Process_Capture()) g_state = ST_DISPLAY;
		else g_state = ST_ERROR;
		break;
	case ST_DISPLAY:
		Draw_Result();
		if (g_reset_requested) g_state = ST_TARE;
		break;
	case ST_ERROR:
		Show_Error();
		if (g_reset_requested) g_state = ST_TARE;
		break;
	}
}
```

